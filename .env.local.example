# ─── Neon PostgreSQL ──────────────────────────────────────
# Obtén estos valores en: console.neon.tech → tu proyecto → Connection string
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/bankruptnt?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/bankruptnt?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-algo-muy-secreto-minimo-32-chars"
JWT_EXPIRES_IN="7d"

# ─── Face Recognition ─────────────────────────────────────
# Umbral de distancia euclidiana (0.5 estricto → 0.6 permisivo)
FACE_MATCH_THRESHOLD="0.55"

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
